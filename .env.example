# PostgreSQL（本地可用 Docker/Neon 开发分支）
# Vercel 部署请使用 Neon 的 pooled 连接串（主机名含 -pooler）
DATABASE_URL=postgresql://user:password@localhost:5432/handinhand

# NextAuth — 生产环境必填；生成：openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_TRUST_HOST=true

# Cloudflare R2 对象存储（生产环境推荐；本地开发可省略，回退到 public/uploads/）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# 生产 seed：必须设置强密码；勿使用默认测试密码
SEED_ADMIN_PASSWORD=
# 生产环境默认不创建演示账号；设为 true 可创建测试老师/家长
SEED_DEMO_DATA=false
