# PostgreSQL
# 本地开发 / Neon：直接填写连接串
# Docker Compose（NAS）：由 docker-compose.yml 注入，只需设置 POSTGRES_PASSWORD
DATABASE_URL=postgresql://user:password@localhost:5432/handinhand

# Docker 基础镜像（飞牛 docker.fnnas.com 401 时可改用镜像加速地址）
# NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
NODE_IMAGE=node:22-alpine

# Docker Compose（NAS 自托管）
POSTGRES_PASSWORD=change-me-in-production
APP_PORT=3000
# 首次 docker compose up 时设为 true，之后改为 false 或删除
RUN_SEED=false

# NextAuth — 生产环境必填；生成：openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_TRUST_HOST=true

# Cloudflare Tunnel（无公网 IP 时可选，见 NAS-DEPLOY.md）
CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare R2 对象存储（Vercel 生产推荐；NAS 自托管可省略，回退到 public/uploads/）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# 生产 seed：必须设置强密码；勿使用默认测试密码
SEED_ADMIN_PASSWORD=
# 生产环境默认不创建演示账号；设为 true 可创建测试老师/家长
SEED_DEMO_DATA=false
